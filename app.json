{
  "expo": {
    "name": "IoT Sign Language Glove",
    "slug": "iot-sign-language",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yigitalp02.iotsignlanguage",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "This app connects to the ASL glove over your local WiFi network."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.yigitalp02.iotsignlanguage",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CHANGE_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "19b46d13-d503-4ba8-b2ad-24cd399d105f"
      }
    }
  }
}
